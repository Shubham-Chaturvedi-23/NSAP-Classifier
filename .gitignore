# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Environment ────────────────────────────────────────────────
.env
.env.*
!.env.example
!backend/.env.example

# ── ML Model Artifacts ─────────────────────────────────────────
# Do NOT commit large model files to git
# Place these manually after cloning:
#   backend/api/ml_models/nsap_catboost_model.cbm
#   backend/api/ml_models/nsap_label_encoder.pkl
#   backend/api/ml_models/nsap_feature_columns.pkl
backend/api/ml_models/*.cbm
backend/api/ml_models/*.pkl
backend/api/ml_models/*.bin

# Old models/ folder path (kept for safety)
models/*.cbm
models/*.pkl
models/*.bin
models/*.pt

# ── Dataset ────────────────────────────────────────────────────
# Large CSV files — do not commit
*.csv
!sample_data/sample_5_records.csv
!ml/fairness_report.csv
!ml/model_comparison.csv

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Node / Frontend ────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Logs ───────────────────────────────────────────────────────
*.log
logs/

# ── Uploads (temp files from OCR) ──────────────────────────────
temp/
uploads/*
!uploads/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# ── ML Output (generated plots) ────────────────────────────────
ml/output/
